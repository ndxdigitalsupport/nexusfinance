# ── Required ─────────────────────────────────────
JWT_SECRET=change_me_to_a_random_secret
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=change_me
SUPABASE_SERVICE_ROLE=change_me

# ── Auth ─────────────────────────────────────────
APPWRITE_ENDPOINT=https://sgp.cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=change_me
APPWRITE_API_KEY=change_me

# ── Server ───────────────────────────────────────
NODE_ENV=production
PORT=3001
CORS_ORIGIN=https://nexusfinancefintech.vercel.app

# ── Google OAuth ──────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://nexusfinance-5okf.onrender.com/api/auth/google/callback

# ── SMS (Twilio — optional, logs to console if empty) ──
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ── Telegram Bot (for testing) ──────────────────
TELEGRAM_BOT_TOKEN=change_me
TELEGRAM_ADMIN_ID=change_me
