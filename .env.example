# Required: JWT secret key for authentication tokens
JWT_SECRET=your-secret-key-here

# Supabase credentials (required)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE=your-service-role-key

# CORS origin — set to your production domain in production (e.g. https://nexusfinance.railway.app)
# Defaults to http://localhost:3000 in dev
CORS_ORIGIN=http://localhost:3000

# Bakong (NBC) API — for real KHQR payment processing
# Get token from Bakong developer portal: https://bakong.nbc.gov.kh
BAKONG_API_BASE_URL=https://sit-api-bakong.nbc.gov.kh/v1
BAKONG_TOKEN=your-bakong-jwt-token-here
BAKONG_MERCHANT_ID=your-bakong-merchant-id-here
BAKONG_MERCHANT_NAME=NexusFinance

# SentDM for OTP SMS (optional — OTP logs to console in dev)
SENT_DM_API_KEY=
SENT_OTP_TEMPLATE_ID=

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email via SendGrid (preferred — 100/day free, no DNS needed)
# Sign up at https://sendgrid.com → Settings → API Keys → Create Key
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=your-verified-sender@example.com

# Resend (fallback — requires DNS domain verification)
# Sign up at https://resend.com → create API key
RESEND_API_KEY=

# Telegram bot (optional — enables /stats /loans /users /notifications commands)
# Get token from https://t.me/BotFather
# Get your user ID by messaging @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_ID=
SITE_URL=https://your-site.onrender.com