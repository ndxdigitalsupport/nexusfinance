# Required: JWT secret key for authentication tokens
JWT_SECRET=your-secret-key-here

# Comma-separated list of allowed CORS origins (optional, defaults to http://localhost:3000)
CORS_ORIGIN=http://localhost:3000

# Supabase credentials (required)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE=your-service-role-key

# SentDM for OTP SMS (optional — OTP logs to console in dev)
SENT_DM_API_KEY=
SENT_OTP_TEMPLATE_ID=

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
